<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
     <record id="inherit_sale_price_control_sale_order_form_view" model="ir.ui.view">
        <field name="name">inherit.sale.price.control.sale.order.form.view</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='order_lines']//field[@name='order_line']//list//field[@name='price_unit']" position="after">
                    <field name="sale_minimum_price" optional="hide" groups="ps_sale_price_control.group_sale_price_control" />
            </xpath>
            <xpath expr="//field[@name='sale_order_template_id']" position="after">
                <field name="is_sale_price_control" readonly="0"/>
            </xpath>
        </field>
    </record>
</odoo>
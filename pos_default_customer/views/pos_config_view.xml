<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_pos_config_form_default_customer" model="ir.ui.view">
        <field name="name">pos.config.form.default.customer</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">

            <!-- Insertion après le premier groupe -->
            <xpath expr="//sheet/group" position="after">
                <group string="Client par défaut">
                    <field name="default_partner_id"/>
                </group>
            </xpath>

        </field>
    </record>
</odoo>

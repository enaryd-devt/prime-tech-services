                <tr>
                    <td style="width:50%; text-align:left;">
                        <strong>CAISSIER</strong><br/>
                        <t t-esc="o.create_uid.name"/>
                        <br/><br/>
                        ______________________
                    </td>

                    <td style="width:50%; text-align:right;">
                        <strong>CLIENT</strong><br/>
                        <t t-esc="o.partner_id.name"/>
                        <br/><br/>
                        ______________________
                    </td>
                </tr>
            </table>

        </xpath>
    </template>

</odoo>

                        <strong>LE VENDEUR</strong><br/>
                        <t t-esc="o.user_id.name"/>
                        <br/><br/>
                        ______________________
                    </td>

                    <td style="width:50%; text-align:right;">
                        <strong>LE CLIENT</strong><br/>
                        <t t-esc="o.partner_id.name"/>
                        <br/><br/>
                        ______________________
                    </td>
                </tr>
            </table>

        </xpath>
    </template>

    <!-- ================= REÇU DE PAIEMENT ================= -->
